        <!-- Sun disc -->
        <path
            android:fillColor="#FCD34D"
            android:pathData="M 54 36 m -15 0 a 15 15 0 1 0 30 0 a 15 15 0 1 0 -30 0" />

        <!-- 8 rays -->
