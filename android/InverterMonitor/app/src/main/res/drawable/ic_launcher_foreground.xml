              android:pathData="M 52 48 L 56 48 L 55 56 L 53 56 Z" />
        <path android:fillColor="#FCD34D"
              android:pathData="M 72 34 L 72 38 L 64 37 L 64 35 Z" />
        <path android:fillColor="#FCD34D"
              android:pathData="M 36 34 L 36 38 L 44 37 L 44 35 Z" />
        <path android:fillColor="#FCD34D"
              android:pathData="M 67 20 L 70 23 L 64 28 L 61 25 Z" />
        <path android:fillColor="#FCD34D"
              android:pathData="M 41 20 L 38 23 L 44 28 L 47 25 Z" />
        <path android:fillColor="#FCD34D"
              android:pathData="M 67 52 L 70 49 L 64 44 L 61 47 Z" />
        <path android:fillColor="#FCD34D"
              android:pathData="M 41 52 L 38 49 L 44 44 L 47 47 Z" />

