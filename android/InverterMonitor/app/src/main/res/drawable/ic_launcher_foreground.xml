                android:fillColor="#1D3C66"
                android:pathData="M 34 76 v 12 M 48 76 v 12 M 62 76 v 12 M 76 76 v 12 M 20 82 h 68" />
            <!-- Gold outline for the panel, matching the iOS icon accent -->
            <path
                android:fillColor="#00000000"
                android:strokeColor="#FCD34D"
                android:strokeWidth="1.5"
                android:pathData="M 26 70 h 56 a 6 6 0 0 1 6 6 v 12 a 6 6 0 0 1 -6 6 h -56 a 6 6 0 0 1 -6 -6 v -12 a 6 6 0 0 1 6 -6 Z" />
        </group>
