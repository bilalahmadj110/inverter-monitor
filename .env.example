# Required: long random string used to sign session cookies.
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
INVERTER_SECRET_KEY=

# Required: dashboard login password. Pick a strong, unique one (>=8 chars).
INVERTER_ADMIN_PASSWORD=

# Optional: dashboard login username (defaults to "admin").
# INVERTER_ADMIN_USERNAME=admin

# Optional: idle session timeout in minutes (default 60).
# INVERTER_SESSION_MINUTES=60

# Optional: when fronted by Cloudflare/HTTPS proxy, set to 1 (default 1).
# Set to 0 only when accessing directly over plain HTTP on a trusted LAN.
# BEHIND_PROXY=1

# Optional: SocketIO allowed origins (comma-separated). Empty = same-origin only.
# ALLOWED_ORIGINS=https://inverter.example.com

# Optional: bind address (default 0.0.0.0). Set to 127.0.0.1 to disable LAN access
# and only allow Cloudflare Tunnel running on the same host.
# BIND_HOST=0.0.0.0

# Optional: OpenAI API key for the AI Q&A box on the Savings page.
# Without it, the box is disabled — savings, payback, and slab projections
# still work without an API key.
# OPENAI_API_KEY=sk-...

# Optional: override the OpenAI model used for Q&A. Default is gpt-4o-mini.
# OPENAI_MODEL=gpt-4o-mini
